# =============================================================================
# STBcheck Configuration
# =============================================================================
# Copy this file to .env and modify values as needed.
# All values have sensible defaults - no .env file is required for development.
# =============================================================================

# =============================================================================
# Timeouts (in seconds)
# =============================================================================

# Timeout for HTTP requests to portals (default: 10)
REQUEST_TIMEOUT=10

# Timeout for streaming operations like proxy and concurrent checks (default: 20)
STREAM_TIMEOUT=20

# Timeout for fetching logo images (default: 5)
LOGO_FETCH_TIMEOUT=5

# =============================================================================
# Concurrency Limits
# =============================================================================

# Maximum number of concurrent portal checks - semaphore limit (default: 15)
MAX_CONCURRENT_PORTAL_CHECKS=15

# =============================================================================
# Logging Configuration
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Maximum size of log file before rotation in bytes (default: 5242880 = 5MB)
LOG_FILE_MAX_BYTES=5242880

# Number of backup log files to keep (default: 2)
LOG_BACKUP_COUNT=2

# =============================================================================
# CORS Configuration
# =============================================================================

# Comma-separated list of allowed CORS origins, or '*' for all (default: *)
# Example for production: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# SECURITY NOTE: Use '*' only for development!
CORS_ORIGINS=*

# =============================================================================
# Server Configuration
# =============================================================================

# Host address to bind the server to (default: 0.0.0.0)
SERVER_HOST=0.0.0.0

# Port number for the server (default: 8000)
SERVER_PORT=8000

# =============================================================================
# Application Settings
# =============================================================================

# Application version string (default: 1.0.1 - Playback Fixes)
APP_VERSION=1.0.1 - Playback Fixes
